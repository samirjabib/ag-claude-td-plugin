{
  "manifest_version": 3,
  "name": "TD Claude Bridge",
  "version": "0.0.1",
  "description": "Bridges Time Doctor 2 timer events on Monday.com to a local Claude MCP server.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage", "identity", "identity.email", "alarms"],
  "host_permissions": [
    "*://*.monday.com/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://*.monday.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
